{
  "name": "content-analyzer",
  "version": "1.0.0",
  "description": "Local-first, ML-powered content engagement analyzer for PDFs, images, and URLs.",
  "type": "module",
  "author": "Parv Sojatia",
  "license": "MIT",
  "keywords": [
    "content-analysis",
    "engagement-optimization",
    "local-ml",
    "transformers-js",
    "sentiment-analysis",
    "social-media-hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/parvsojatia/unthinkable"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "test": "vitest run",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}